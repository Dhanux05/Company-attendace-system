PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sninfo
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
